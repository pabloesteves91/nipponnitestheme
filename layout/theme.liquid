<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="canonical" href="{{ canonical_url }}">
  <meta name="robots" content="index, follow">
  <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {% assign meta_desc = page_description | default: shop.description %}
  {% if meta_desc %}<meta name="description" content="{{ meta_desc | escape }}">{% endif %}
  <link rel="icon" type="image/png" href="{{ 'logo_nippon.png' | file_img_url: '64x64' }}">
  <link rel="apple-touch-icon" href="{{ 'logo_nippon.png' | file_img_url: '180x180' }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {% if meta_desc %}<meta property="og:description" content="{{ meta_desc | escape }}">{% endif %}
  <meta property="og:image" content="{{ 'logo_nippon.png' | file_img_url: '1200x630' }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {% if meta_desc %}<meta name="twitter:description" content="{{ meta_desc | escape }}">{% endif %}
  <meta name="twitter:image" content="{{ 'logo_nippon.png' | file_img_url: '1200x630' }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ shop.name | escape }}",
    "url": "{{ shop.url }}",
    "logo": "{{ 'logo_nippon.png' | file_img_url: '200x200' }}",
    "description": "{{ shop.description | strip_html | escape }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Im Grüntal 10",
      "addressLocality": "Winterthur",
      "postalCode": "8405",
      "addressRegion": "ZH",
      "addressCountry": "CH"
    }
  }
  </script>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;700;900&family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }</style>
  {{ 'theme.min.css' | asset_url | stylesheet_tag }}
</head>
<body class="bg-night text-white font-sans antialiased">
  {% section 'announcement-bar' %}
  {% section 'header' %}
  <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  {% render 'cart-drawer' %}
  <ul hidden><li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li></ul>
  <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
</body>
</html>
