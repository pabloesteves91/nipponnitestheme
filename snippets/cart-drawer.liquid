<script>window.__moneyFormat = {{ shop.money_format | json }};</script>

<!-- Backdrop -->
<div
  id="cart-backdrop"
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[55] opacity-0 pointer-events-none transition-opacity duration-500"
  onclick="closeCartDrawer()"
></div>

<!-- Cart Drawer -->
<aside
  id="cart-drawer"
  class="fixed right-0 top-0 h-full z-[60] flex flex-col p-6 bg-[#131313] w-full md:w-96 shadow-2xl translate-x-full transition-transform duration-500 ease-in-out"
  aria-label="Shopping Cart"
>
  <!-- Header -->
  <div class="flex justify-between items-start mb-12">
    <div>
      <h2 class="font-headline uppercase font-black text-3xl text-primary tracking-tighter">SHOPPING BAG</h2>
      <p class="font-label text-xs tracking-[0.2em] text-white/40 uppercase">READY TO DRIFT</p>
    </div>
    <button onclick="closeCartDrawer()" class="hover:bg-[#353535] p-2 transition-colors" aria-label="Close cart">
      <span class="material-symbols-outlined text-white">close</span>
    </button>
  </div>

  <!-- Items -->
  <div id="cart-drawer-items" class="flex-grow overflow-y-auto space-y-8">
    {% if cart.item_count == 0 %}
      <div class="flex flex-col items-center justify-center h-full gap-4 opacity-30">
        <span class="material-symbols-outlined text-6xl">shopping_bag</span>
        <p class="font-headline uppercase font-bold tracking-tighter">Your bag is empty</p>
      </div>
    {% else %}
      {% for item in cart.items %}
        <div class="flex gap-4 items-start" data-cart-item="{{ item.key }}">
          <a href="{{ item.url }}" class="w-24 h-24 bg-[#1b1b1b] flex-shrink-0 overflow-hidden block">
            {% if item.image %}
              <img
                src="{{ item.image | img_url: '200x200', crop: 'center' }}"
                alt="{{ item.image.alt | escape }}"
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
              >
            {% endif %}
          </a>
          <div class="flex flex-col flex-grow">
            <div class="flex justify-between items-start gap-2">
              <a href="{{ item.url }}" class="font-headline font-bold text-sm tracking-tighter uppercase leading-tight hover:text-primary transition-colors">{{ item.product.title }}</a>
              <button
                onclick="cartRemoveItem('{{ item.key }}')"
                class="text-white/20 hover:text-primary transition-colors flex-shrink-0"
                aria-label="Remove {{ item.product.title | escape }}"
              >
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
            {% unless item.variant.title == 'Default Title' %}
              <span class="text-[10px] text-white/40 uppercase tracking-widest font-label mt-1">{{ item.variant.title }}</span>
            {% endunless %}
            <div class="mt-4 flex justify-between items-center">
              <div class="flex items-center gap-3 bg-[#1b1b1b] px-3 py-1">
                <button
                  onclick="cartUpdateItem('{{ item.key }}', {{ item.quantity | minus: 1 }})"
                  class="text-white/40 hover:text-white transition-colors"
                  aria-label="Decrease quantity"
                >
                  <span class="material-symbols-outlined" style="font-size:14px">remove</span>
                </button>
                <span class="font-headline font-bold text-xs w-5 text-center" data-item-qty="{{ item.key }}">{{ item.quantity | prepend: '0' | slice: -2, 2 }}</span>
                <button
                  onclick="cartUpdateItem('{{ item.key }}', {{ item.quantity | plus: 1 }})"
                  class="text-white/40 hover:text-white transition-colors"
                  aria-label="Increase quantity"
                >
                  <span class="material-symbols-outlined" style="font-size:14px">add</span>
                </button>
              </div>
              <span class="font-headline font-bold text-primary" data-item-price="{{ item.key }}">{{ item.final_line_price | money }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <!-- Footer -->
  <div class="mt-auto pt-8 border-t border-[#353535]">
    <div class="flex justify-between items-center mb-2">
      <span class="font-label text-xs tracking-widest text-white/40 uppercase">SUBTOTAL</span>
      <span id="cart-drawer-subtotal" class="font-headline font-black text-xl text-white">{{ cart.total_price | money }}</span>
    </div>
    <div class="flex justify-between items-center mb-8">
      <span class="font-label text-xs tracking-widest text-white/40 uppercase">SHIPPING</span>
      <span class="font-headline font-bold text-sm text-primary uppercase">AT CHECKOUT</span>
    </div>
    <div id="cart-drawer-cta">
      {% if cart.item_count > 0 %}
        <a
          href="/checkout"
          class="block w-full py-5 bg-gradient-to-br from-[#ffb4a9] to-[#fb5a48] text-[#410000] font-headline font-black uppercase text-center tracking-tighter text-lg hover:brightness-110 active:scale-[0.98] transition-all duration-300"
        >
          PROCEED TO CHECKOUT
        </a>
      {% else %}
        <a
          href="/collections/all"
          class="block w-full py-5 bg-[#353535] text-white/60 font-headline font-black uppercase text-center tracking-tighter text-lg hover:bg-[#ffb4a9] hover:text-[#410000] transition-all duration-300"
        >
          SHOP NOW
        </a>
      {% endif %}
    </div>
    <div class="mt-6 flex justify-between items-center">
      <div class="flex gap-4">
        <span class="material-symbols-outlined text-white/20 text-lg">shopping_bag</span>
        <span class="material-symbols-outlined text-white/20 text-lg">payments</span>
        <span class="material-symbols-outlined text-white/20 text-lg">local_shipping</span>
      </div>
      <span class="font-label text-[10px] tracking-[0.2em] text-white/40 uppercase">PASSION IS NOT A CRIME.</span>
    </div>
  </div>
</aside>
