{%- assign _count = product.metafields.reviews.rating_count | default: 0 | plus: 0 -%}
{%- assign _rating = product.metafields.reviews.rating.value | default: 0 | times: 1.0 -%}
{%- assign _full = _rating | floor -%}
<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:8px;">
  <div style="display:flex;gap:2px;align-items:center;">
    {%- if _count > 0 -%}
      {%- for i in (1..5) -%}
        {%- if i <= _full -%}<span style="color:#ffffff;font-size:15px;line-height:1;">★</span>
        {%- else -%}<span style="color:#ffffff;font-size:15px;line-height:1;opacity:0.25;">★</span>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      <span style="color:#ffffff;font-size:15px;letter-spacing:2px;line-height:1;">☆☆☆☆☆</span>
    {%- endif -%}
  </div>
  <span style="color:rgba(255,255,255,0.28);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.12em;">
    {{ _count }} Bewertungen
  </span>
  {%- if show_button -%}
    <button
      onclick="var f=document.getElementById('jdgm-inline-{{ product.id }}');f.style.display=f.style.display==='none'?'block':'none';"
      style="font-family:'Space Grotesk',sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.12em;color:#ffb4a9;background:transparent;border:1px solid rgba(255,180,169,0.4);padding:3px 10px;cursor:pointer;white-space:nowrap;">
      + Bewertung schreiben
    </button>
  {%- endif -%}
</div>
{%- if show_button -%}
  <style>
    #jdgm-inline-{{ product.id }} input,
    #jdgm-inline-{{ product.id }} textarea,
    #jdgm-inline-{{ product.id }} select { color: #1a1a1a !important; }
    #jdgm-inline-{{ product.id }} input::placeholder,
    #jdgm-inline-{{ product.id }} textarea::placeholder { color: #666666 !important; }
    #jdgm-inline-{{ product.id }} .jdgm-submit-rev-btn { color: #ffffff !important; }
  </style>
  <div id="jdgm-inline-{{ product.id }}" style="display:none;margin-top:16px;">
    <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
      {{ product.metafields.judgeme.widget }}
    </div>
  </div>
{%- endif -%}
