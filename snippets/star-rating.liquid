<div class="flex items-center gap-2 mt-2">
  {%- if product.metafields.judgeme.badge != blank -%}
    <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
      {{ product.metafields.judgeme.badge }}
    </div>
  {%- else -%}
    <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}" style="display:flex;align-items:center;gap:6px;">
      <span style="color:#ffb4a9;font-size:13px;letter-spacing:2px;">☆☆☆☆☆</span>
      <span style="color:rgba(255,255,255,0.25);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">Noch keine Bewertungen</span>
    </div>
  {%- endif -%}
</div>
