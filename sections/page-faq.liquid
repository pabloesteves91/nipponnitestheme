<!-- FAQ Hero -->
<section class="bg-surface pt-32 pb-16 px-8">
  <div class="max-w-4xl mx-auto text-center">
    <span class="font-label text-primary uppercase tracking-[0.4em] text-sm mb-4 block">Support</span>
    <h1 class="font-headline text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-6">FAQ</h1>
    <p class="text-white/40 font-body text-lg max-w-xl mx-auto">Häufig gestellte Fragen. Brauchst du weitere Hilfe?
      <a href="mailto:info@nipponnites.com" class="text-primary hover:brightness-110 transition-all">info@nipponnites.com</a>
    </p>
  </div>
</section>

<!-- FAQ Accordion -->
<section class="bg-surface pb-32 px-8">
  <div class="max-w-3xl mx-auto divide-y divide-white/10">

    <!-- Group: Bestellungen -->
    <div class="py-6">
      <p class="font-headline font-bold text-sm uppercase tracking-[0.3em] text-primary mb-6">Bestellungen & Versand</p>
      <div class="space-y-0 divide-y divide-white/5">

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Wie lange dauert die Lieferung?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Standard ca. 10 Tage — die Shirts werden direkt für dich gedruckt. So sparen wir Lagerkosten und sind transparent. Custom Designs: 1–2 Wochen Produktion + ca. 10 Tage Lieferung. Dafür bekommst du etwas Perfektes.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Liefert ihr international?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Ja! Wir liefern weltweit. Schweiz & Deutschland: 7–12 Werktage. Europa: 10–15 Werktage. USA & Rest der Welt: 10–20 Werktage. Alle Zeiten inkl. Produktion & Versand.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Wie verfolge ich meine Bestellung?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Nach dem Versand erhältst du automatisch eine E-Mail mit einem Tracking-Link. Bei Fragen schreib uns: <a href="mailto:info@nipponnites.com" class="text-primary hover:brightness-110">info@nipponnites.com</a>
          </p>
        </details>

      </div>
    </div>

    <!-- Group: Rückgabe -->
    <div class="py-6">
      <p class="font-headline font-bold text-sm uppercase tracking-[0.3em] text-primary mb-6">Rückgabe & Umtausch</p>
      <div class="space-y-0 divide-y divide-white/5">

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Kann ich zurückgeben oder umtauschen?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Standard-Produkte können innerhalb von 14 Tagen zurückgegeben oder umgetauscht werden — ungetragen und mit Etikett. Custom-Bestellungen (eigenes Design) sind von der Rückgabe ausgeschlossen, da sie speziell für dich angefertigt wurden.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Was mache ich bei einem falschen oder beschädigten Artikel?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Schreib uns sofort an <a href="mailto:info@nipponnites.com" class="text-primary hover:brightness-110">info@nipponnites.com</a> mit Foto und Bestellnummer. Wir kümmern uns umgehend darum.
          </p>
        </details>

      </div>
    </div>

    <!-- Group: Custom -->
    <div class="py-6">
      <p class="font-headline font-bold text-sm uppercase tracking-[0.3em] text-primary mb-6">Custom Bestellungen</p>
      <div class="space-y-0 divide-y divide-white/5">

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Wie funktioniert eine Custom-Bestellung?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            1. Bestelle deinen Custom Hoodie oder T-Shirt im Shop. 2. Nach der Bestellung kontaktieren wir dich per E-Mail. 3. Du schickst uns Fotos deines Fahrzeugs und deine Design-Ideen. 4. Wir illustrieren dein Unikat von Hand. 5. Produktion & Versand.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Kann ich mein eigenes Logo oder Design einsenden?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Ja! Schick uns deine Idee, Skizze oder Referenzbilder. Wir setzen das gemeinsam mit dir in unser Hand-illustriertes Design um.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Welche Fahrzeuge könnt ihr illustrieren?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Jedes Fahrzeug! JDM-Klassiker, europäische Sportwagen, Muscle Cars, Tuning-Projekte — wenn du es fährst, illustrieren wir es.
          </p>
        </details>

      </div>
    </div>

    <!-- Group: Produkt -->
    <div class="py-6">
      <p class="font-headline font-bold text-sm uppercase tracking-[0.3em] text-primary mb-6">Produkt & Material</p>
      <div class="space-y-0 divide-y divide-white/5">

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Aus welchem Material sind eure Hoodies?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Wir verwenden 100% Bio-Baumwolle (450GSM) — schwer, weich und langlebig. Kein billiges Fleece, echte Qualität die den Alltag übersteht.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Wie pflege ich meinen Hoodie?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Waschen auf links gedreht bei max. 30°C. Nicht im Trockner. Bügeln bei niedriger Temperatur — Druckbereiche aussparen. So bleibt das Design jahrelang scharf.
          </p>
        </details>

        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-5 list-none">
            <span class="font-headline font-bold uppercase tracking-tight text-lg">Wie fällt die Grösse aus?</span>
            <span class="text-primary text-2xl group-open:rotate-45 transition-transform duration-200 shrink-0 ml-4">+</span>
          </summary>
          <p class="text-white/50 font-body text-base leading-relaxed pb-5">
            Unsere Hoodies sind im Oversized-Schnitt gehalten — das ist Absicht. Im Zweifel eine Grösse grösser wählen für den vollen Streetwear-Look. Die Grössentabelle findest du auf jeder Produktseite.
          </p>
        </details>

      </div>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="bg-surface-container-low border-t border-white/5 py-20 px-8 text-center">
  <p class="text-white/40 font-body mb-4">Deine Frage ist nicht dabei?</p>
  <a href="mailto:info@nipponnites.com" class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-headline font-bold uppercase py-4 px-12 tracking-widest hover:brightness-110 active:scale-95 transition-all">
    Schreib uns
  </a>
</section>

{% schema %}
{
  "name": "FAQ Page",
  "settings": []
}
{% endschema %}
