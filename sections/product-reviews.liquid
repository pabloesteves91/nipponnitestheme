<section class="bg-surface py-20 px-8">
  <div class="max-w-screen-xl mx-auto">
    <div class="mb-12">
      <p class="font-label text-xs tracking-[0.3em] uppercase text-primary mb-2">Was andere sagen</p>
      <h2 class="font-headline font-black text-4xl md:text-5xl uppercase tracking-tighter leading-none">Bewertungen</h2>
    </div>

    <!-- Judge.me Reviews Widget -->
    <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
      {{ product.metafields.judgeme.badge }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Produktbewertungen",
  "settings": [],
  "presets": [{ "name": "Produktbewertungen" }]
}
{% endschema %}
