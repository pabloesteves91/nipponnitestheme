<header class="sticky top-0 z-50 bg-[#131313]/80 backdrop-blur-xl shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
  <div class="px-6 lg:px-10">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center no-underline shrink-0">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | img_url: '400x' }}"
            alt="{{ shop.name }}"
            class="h-14 w-auto object-contain"
          >
        {% else %}
          <span class="font-headline font-black italic tracking-tighter text-2xl text-primary">{{ shop.name | upcase }}</span>
        {% endif %}
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-10">
        {% for link in linklists[section.settings.menu].links %}
          <a
            href="{{ link.url }}"
            class="font-headline font-bold text-sm uppercase tracking-widest text-white/60 hover:text-white transition-colors{% if link.active %} text-white{% endif %}"
          >{{ link.title }}</a>
        {% endfor %}
      </nav>

      <!-- Icons -->
      <div class="flex items-center gap-5">
        <a href="/search" class="text-white/60 hover:text-white transition-colors" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        </a>
        <button onclick="openCartDrawer()" class="relative text-white/60 hover:text-white transition-colors" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          <span data-cart-count class="cart-badge" hidden>0</span>
        </button>
        <button id="mobile-menu-btn" class="md:hidden text-white/60 hover:text-white" aria-expanded="false" aria-label="Menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="hidden md:hidden border-t border-white/10 bg-[#131313]">
    <div class="px-6 py-6 flex flex-col gap-5">
      {% for link in linklists[section.settings.menu].links %}
        <a
          href="{{ link.url }}"
          class="font-headline font-bold uppercase tracking-widest text-white/60 hover:text-white transition-colors"
        >{{ link.title }}</a>
      {% endfor %}
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Navigation", "default": "main-menu" }
  ]
}
{% endschema %}
