<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | escape }}",
  "image": "{{ product.featured_image | img_url: '1200x' }}",
  "brand": { "@type": "Brand", "name": "{{ shop.name | escape }}" },
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price | money_without_currency }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}"
  }
}
</script>
<div class="grid grid-cols-1 md:grid-cols-12 min-h-screen">

  <!-- Left: Visual Column -->
  <div class="md:col-span-7 bg-surface p-4 md:p-12 space-y-8">
    <!-- Image Slider -->
    <div id="pdp-slider" class="relative aspect-[3/4] overflow-hidden bg-surface-container-low select-none">
      <!-- Slides track -->
      <div id="pdp-slides" style="display:flex; transition:transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94); will-change:transform; height:100%;">
        {% for image in product.images %}
          <div style="min-width:100%; height:100%; flex-shrink:0;">
            <img src="{{ image | img_url: '1000x1333', crop: 'center' }}"
                 alt="{{ image.alt | default: product.title | escape }}"
                 style="width:100%; height:100%; object-fit:cover; display:block;">
          </div>
        {% endfor %}
      </div>

      <!-- Prev / Next arrows (only if more than 1 image) -->
      {% if product.images.size > 1 %}
        <button onclick="pdpSlide(-1)" aria-label="Vorheriges Bild"
          style="position:absolute; left:0.75rem; top:50%; transform:translateY(-50%); background:rgba(19,19,19,0.75); border:1px solid rgba(255,255,255,0.15); color:#ffb4a9; width:2.5rem; height:2.5rem; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; transition:background 0.2s; padding:0;">
          <span class="material-symbols-outlined" style="font-size:20px;">chevron_left</span>
        </button>
        <button onclick="pdpSlide(1)" aria-label="Nächstes Bild"
          style="position:absolute; right:0.75rem; top:50%; transform:translateY(-50%); background:rgba(19,19,19,0.75); border:1px solid rgba(255,255,255,0.15); color:#ffb4a9; width:2.5rem; height:2.5rem; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; transition:background 0.2s; padding:0;">
          <span class="material-symbols-outlined" style="font-size:20px;">chevron_right</span>
        </button>
        <!-- Dot indicators -->
        <div style="position:absolute; bottom:1rem; left:50%; transform:translateX(-50%); display:flex; gap:0.4rem; z-index:10;">
          {% for image in product.images %}
            <button onclick="pdpGoTo({{ forloop.index0 }})"
              aria-label="Bild {{ forloop.index }}"
              class="pdp-dot"
              style="width:0.4rem; height:0.4rem; border-radius:9999px; border:none; cursor:pointer; padding:0; transition:background 0.2s; background:{% if forloop.first %}#ffb4a9{% else %}rgba(255,255,255,0.3){% endif %};">
            </button>
          {% endfor %}
        </div>
      {% endif %}

      <!-- Limited badge -->
      {% if product.tags contains 'limited' %}
        <div style="position:absolute; top:2rem; left:2rem; z-index:10;">
          <span class="bg-surface-container-highest px-4 py-1 text-primary text-xs font-label tracking-[0.2em] uppercase flex items-center gap-2">
            <span class="w-2 h-2 bg-primary animate-pulse rounded-full"></span>
            Limited Edition
          </span>
        </div>
      {% endif %}
    </div>

    <script>
      (function() {
        var _cur = 0;
        var _total = {{ product.images.size }};
        var _touchStartX = 0;

        function _update() {
          var track = document.getElementById('pdp-slides');
          if (track) track.style.transform = 'translateX(-' + (_cur * 100) + '%)';
          document.querySelectorAll('.pdp-dot').forEach(function(d, i) {
            d.style.background = (i === _cur) ? '#ffb4a9' : 'rgba(255,255,255,0.3)';
          });
        }

        window.pdpSlide = function(dir) {
          _cur = (_cur + dir + _total) % _total;
          _update();
        };

        window.pdpGoTo = function(idx) {
          _cur = idx;
          _update();
        };

        // Touch / swipe support
        var sl = document.getElementById('pdp-slider');
        if (sl) {
          sl.addEventListener('touchstart', function(e) {
            _touchStartX = e.touches[0].clientX;
          }, { passive: true });
          sl.addEventListener('touchend', function(e) {
            var dx = e.changedTouches[0].clientX - _touchStartX;
            if (Math.abs(dx) > 40) pdpSlide(dx < 0 ? 1 : -1);
          }, { passive: true });
        }
      })();
    </script>

    <!-- Technical Specs -->
    {% if product.description != blank %}
      <div class="pt-20 pb-12">
        <h3 class="font-headline text-2xl font-bold uppercase tracking-tight mb-8">Technical Specs</h3>
        <div class="text-white/50 font-body text-sm leading-relaxed max-w-xl">
          {{ product.description }}
        </div>
      </div>
    {% endif %}
  </div>

  <!-- Right: Sticky Purchase Column -->
  <div class="md:col-span-5 bg-surface-container-low p-8 md:p-16 md:sticky md:top-20 h-fit">
    <div class="flex flex-col gap-8">

      <!-- Title & Price -->
      <div class="space-y-2">
        {% if product.type != blank %}
          <h2 class="text-white/40 font-label text-sm tracking-[0.3em] uppercase">{{ product.type }}</h2>
        {% endif %}
        <h1 class="text-5xl md:text-7xl font-headline font-black tracking-tighter uppercase leading-none">
          {{ product.title | split: ' ' | first }}<br>
          <span class="text-primary">{{ product.title | split: ' ' | last }}</span>
        </h1>
        <p id="product-price" class="text-2xl font-headline font-bold mt-4">{{ product.price | money }}</p>
      </div>

      <!-- Short description -->
      {% if product.metafields.custom.short_description != blank %}
        <p class="text-white/70 font-body leading-relaxed max-w-md">
          {{ product.metafields.custom.short_description }}
        </p>
      {% endif %}

      {% form 'product', product %}

        <!-- Variant selectors — buttons for every option -->
        <div>
          {% for option in product.options_with_values %}
            <div data-option-index="{{ forloop.index }}" style="margin-bottom:1.5rem;">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
                <label style="font-family:'Space Grotesk',sans-serif; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.15em; color:rgba(255,255,255,0.5);">{{ option.name }}</label>
                {% if forloop.last %}
                  <button type="button" onclick="document.getElementById('size-guide-modal').classList.remove('hidden')"
                    style="font-family:'Space Grotesk',sans-serif; font-size:0.625rem; text-transform:uppercase; letter-spacing:0.1em; color:#ffb4a9; text-decoration:underline; background:none; border:none; cursor:pointer; padding:0;">
                    Grössentabelle
                  </button>
                {% endif %}
              </div>
              <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
                {% for value in option.values %}
                  <button type="button"
                    data-option="{{ forloop.parentloop.index }}"
                    data-value="{{ value | escape }}"
                    onclick="selectVariantOption({{ forloop.parentloop.index }}, '{{ value | escape }}', this)"
                    style="height:3rem; padding:0 1.25rem; border:1px solid {% if forloop.first %}#ffb4a9{% else %}rgba(255,255,255,0.15){% endif %}; color:{% if forloop.first %}#ffb4a9{% else %}rgba(255,255,255,0.7){% endif %}; background:{% if forloop.first %}rgba(255,180,169,0.1){% else %}transparent{% endif %}; font-family:'Space Grotesk',sans-serif; font-size:0.875rem; text-transform:uppercase; letter-spacing:0.1em; cursor:pointer; transition:all 0.15s ease;">
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <input type="hidden" name="id" id="variant-id" value="{{ product.variants.first.id }}">
        </div>

        <script>
          var _variants = {{ product.variants | json }};
          var _selected = {};
          {% for option in product.options_with_values %}
            _selected[{{ forloop.index }}] = '{{ option.values.first | escape }}';
          {% endfor %}

          function selectVariantOption(idx, value, el) {
            _selected[idx] = value;
            // Update button styles in this option group
            var group = el.closest('[data-option-index]');
            group.querySelectorAll('button[data-option]').forEach(function(b) {
              b.style.borderColor = 'rgba(255,255,255,0.15)';
              b.style.color = 'rgba(255,255,255,0.7)';
              b.style.background = 'transparent';
            });
            el.style.borderColor = '#ffb4a9';
            el.style.color = '#ffb4a9';
            el.style.background = 'rgba(255,180,169,0.1)';
            // Find matching variant
            var match = _variants.find(function(v) {
              return v.options.every(function(opt, i) {
                return _selected[i + 1] === opt;
              });
            });
            if (match) {
              document.getElementById('variant-id').value = match.id;
              // Update displayed price
              var priceEl = document.getElementById('product-price');
              if (priceEl && window.__moneyFormat) {
                var fmt = window.__moneyFormat;
                var amount = (match.price / 100).toFixed(2);
                priceEl.textContent = fmt
                  .replace('{{amount}}', amount)
                  .replace('{{amount_with_comma_separator}}', amount.replace('.', ','))
                  .replace('{{amount_no_decimals}}', String(Math.floor(match.price / 100)));
              }
            }
          }
        </script>

        <!-- CTAs -->
        <div class="space-y-4 pt-4">
          {% if product.available %}
            <button type="submit" name="add"
                    class="w-full bg-gradient-to-r from-primary to-primary-container h-16 text-on-primary-fixed font-headline font-extrabold uppercase tracking-widest hover:scale-[1.02] active:scale-95 transition-transform">
              In den Warenkorb legen
            </button>
          {% else %}
            <button disabled
                    class="w-full bg-surface-container-highest h-16 text-white/30 font-headline font-extrabold uppercase tracking-widest cursor-not-allowed">
              Ausverkauft
            </button>
          {% endif %}
          {{ form | payment_button }}
        </div>

      {% endform %}

      <!-- Accordion -->
      <div class="border-t border-white/10 pt-8 mt-4 space-y-6">
        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-2 list-none">
            <h4 class="font-label uppercase tracking-widest text-sm">Shipping & Returns</h4>
            <span class="text-primary text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-xs text-white/50 leading-relaxed font-body mt-3">
            Express shipping worldwide. Swiss orders arrive in 2-3 business days. Free returns within 14 days.
          </p>
        </details>
        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-2 list-none">
            <h4 class="font-label uppercase tracking-widest text-sm">Materials & Care</h4>
            <span class="text-primary text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-xs text-white/50 leading-relaxed font-body mt-3">
            Wash cold inside out. Do not tumble dry. Iron on low heat (exclude print areas).
          </p>
        </details>
      </div>

    </div>
  </div>
</div>

<!-- Size Guide Modal -->
<div id="size-guide-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="document.getElementById('size-guide-modal').classList.add('hidden')"></div>
  <div class="relative bg-surface-container-low border border-outline-variant w-full max-w-lg p-8 z-10">
    <div class="flex justify-between items-center mb-8">
      <h3 class="font-headline font-black text-2xl uppercase tracking-tighter">Grössentabelle</h3>
      <button onclick="document.getElementById('size-guide-modal').classList.add('hidden')" class="text-white/40 hover:text-white text-2xl leading-none">×</button>
    </div>
    <p class="text-white/40 text-xs font-body mb-6 uppercase tracking-widest">Alle Masse in Zentimetern (cm)</p>
    <table class="w-full text-sm font-body">
      <thead>
        <tr class="border-b border-white/10">
          <th class="text-left py-3 font-headline text-xs uppercase tracking-widest text-white/40">Grösse</th>
          <th class="text-center py-3 font-headline text-xs uppercase tracking-widest text-white/40">Brust</th>
          <th class="text-center py-3 font-headline text-xs uppercase tracking-widest text-white/40">Länge</th>
          <th class="text-center py-3 font-headline text-xs uppercase tracking-widest text-white/40">Schulter</th>
          <th class="text-center py-3 font-headline text-xs uppercase tracking-widest text-white/40">Ärmel</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-white/5 hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">XS</td><td class="py-3 text-center text-white/70">86</td><td class="py-3 text-center text-white/70">64</td><td class="py-3 text-center text-white/70">41</td><td class="py-3 text-center text-white/70">62</td></tr>
        <tr class="border-b border-white/5 hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">S</td><td class="py-3 text-center text-white/70">92</td><td class="py-3 text-center text-white/70">66</td><td class="py-3 text-center text-white/70">43</td><td class="py-3 text-center text-white/70">64</td></tr>
        <tr class="border-b border-white/5 hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">M</td><td class="py-3 text-center text-white/70">100</td><td class="py-3 text-center text-white/70">68</td><td class="py-3 text-center text-white/70">46</td><td class="py-3 text-center text-white/70">66</td></tr>
        <tr class="border-b border-white/5 hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">L</td><td class="py-3 text-center text-white/70">108</td><td class="py-3 text-center text-white/70">72</td><td class="py-3 text-center text-white/70">49</td><td class="py-3 text-center text-white/70">68</td></tr>
        <tr class="border-b border-white/5 hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">XL</td><td class="py-3 text-center text-white/70">116</td><td class="py-3 text-center text-white/70">74</td><td class="py-3 text-center text-white/70">52</td><td class="py-3 text-center text-white/70">70</td></tr>
        <tr class="hover:bg-white/5"><td class="py-3 font-headline font-bold text-primary">XXL</td><td class="py-3 text-center text-white/70">124</td><td class="py-3 text-center text-white/70">76</td><td class="py-3 text-center text-white/70">55</td><td class="py-3 text-center text-white/70">72</td></tr>
      </tbody>
    </table>
    <p class="text-white/30 text-xs font-body mt-6">Tipp: Im Zweifel eine Grösse grösser wählen — Oversized sitzt bei Nippon Nites am besten.</p>
  </div>
</div>

{% schema %}
{
  "name": "Main Product – Night Runner",
  "settings": []
}
{% endschema %}
