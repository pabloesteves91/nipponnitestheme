<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <div class="space-y-4">
      <div class="aspect-square bg-card overflow-hidden rounded-sm">
        {% if product.featured_image %}<img id="main-image" src="{{ product.featured_image | img_url: '1000x1000', crop: 'center' }}" alt="{{ product.featured_image.alt | escape }}" class="w-full h-full object-cover">{% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="grid grid-cols-4 gap-2">
          {% for image in product.images limit: 4 %}
            <button onclick="document.getElementById('main-image').src='{{ image | img_url: '600x600', crop: 'center' }}'" class="aspect-square bg-card overflow-hidden rounded-sm border border-transparent hover:border-primary transition-colors">
              <img src="{{ image | img_url: '150x150', crop: 'center' }}" alt="{{ image.alt | escape }}" class="w-full h-full object-cover">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="sticky top-24">
      <p class="font-display text-primary text-xs font-bold uppercase tracking-widest mb-2">{{ product.type }}</p>
      <h1 class="font-display font-black text-4xl text-white mb-4">{{ product.title }}</h1>
      <div class="flex items-center gap-3 mb-6">
        <span class="text-2xl font-bold text-white">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}<span class="text-white/40 line-through">{{ product.compare_at_price | money }}</span><span class="bg-primary text-white text-xs font-display font-bold px-2 py-1 uppercase">Sale</span>{% endif %}
      </div>
      <div class="prose prose-invert text-white/70 text-sm mb-8 max-w-none">{{ product.description }}</div>
      {% form 'product', product %}
        {% if product.variants.size > 1 %}
          <div class="mb-6">
            <label for="variant-select" class="block text-xs font-display font-bold uppercase tracking-widest text-white/40 mb-2">{{ product.options.first }}</label>
            <select id="variant-select" name="id" class="w-full bg-card border border-white/10 text-white font-display text-sm px-4 py-3 focus:border-primary focus:outline-none transition-colors">
              {% for variant in product.variants %}<option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>{{ variant.title }}{% unless variant.available %} – Sold Out{% endunless %}</option>{% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% endif %}
        <div class="flex flex-col gap-3">
          {% if product.available %}<button type="submit" name="add" class="btn-primary w-full py-4 text-base">Add to Cart — {{ product.price | money }}</button>
          {% else %}<button disabled class="btn-primary w-full py-4 text-base opacity-40 cursor-not-allowed">Sold Out</button>{% endif %}
          {{ form | payment_button }}
        </div>
      {% endform %}
    </div>
  </div>
</div>
{% schema %}{"name":"Main Product","settings":[]}{% endschema %}
