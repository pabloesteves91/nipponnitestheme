<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | escape }}",
  "image": "{{ product.featured_image | img_url: '1200x' }}",
  "brand": { "@type": "Brand", "name": "{{ shop.name | escape }}" },
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price | money_without_currency }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}"
  }
}
</script>
<div class="grid grid-cols-1 md:grid-cols-12 min-h-screen">

  <!-- Left: Visual Column -->
  <div class="md:col-span-7 bg-surface p-4 md:p-12 space-y-8">
    <div class="relative aspect-[3/4] overflow-hidden bg-surface-container-low group">
      {% if product.featured_image %}
        <img id="main-product-image"
             src="{{ product.featured_image | img_url: '1000x1333', crop: 'center' }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             class="w-full h-full object-cover">
      {% endif %}
      <!-- Limited badge -->
      {% if product.tags contains 'limited' %}
        <div class="absolute top-8 left-8">
          <span class="bg-surface-container-highest px-4 py-1 text-primary text-xs font-label tracking-[0.2em] uppercase flex items-center gap-2">
            <span class="w-2 h-2 bg-primary animate-pulse rounded-full"></span>
            Limited Edition
          </span>
        </div>
      {% endif %}
    </div>

    <!-- Thumbnail grid -->
    {% if product.images.size > 1 %}
      <div class="grid grid-cols-2 gap-8">
        {% for image in product.images offset: 1 limit: 2 %}
          <div class="{% if forloop.last %}translate-y-12{% endif %} aspect-square bg-surface-container-low overflow-hidden">
            <img src="{{ image | img_url: '600x600', crop: 'center' }}"
                 alt="{{ image.alt | default: product.title | escape }}"
                 class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500 cursor-pointer"
                 onclick="document.getElementById('main-product-image').src='{{ image | img_url: '1000x1333', crop: 'center' }}'">
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <!-- Technical Specs -->
    {% if product.description != blank %}
      <div class="pt-20 pb-12">
        <h3 class="font-headline text-2xl font-bold uppercase tracking-tight mb-8">Technical Specs</h3>
        <div class="text-white/50 font-body text-sm leading-relaxed max-w-xl">
          {{ product.description }}
        </div>
      </div>
    {% endif %}
  </div>

  <!-- Right: Sticky Purchase Column -->
  <div class="md:col-span-5 bg-surface-container-low p-8 md:p-16 md:sticky md:top-20 h-fit">
    <div class="flex flex-col gap-8">

      <!-- Title & Price -->
      <div class="space-y-2">
        {% if product.type != blank %}
          <h2 class="text-white/40 font-label text-sm tracking-[0.3em] uppercase">{{ product.type }}</h2>
        {% endif %}
        <h1 class="text-5xl md:text-7xl font-headline font-black tracking-tighter uppercase leading-none">
          {{ product.title | split: ' ' | first }}<br>
          <span class="text-primary">{{ product.title | split: ' ' | last }}</span>
        </h1>
        <p class="text-2xl font-headline font-bold mt-4">{{ product.price | money }}</p>
      </div>

      <!-- Short description -->
      {% if product.metafields.custom.short_description != blank %}
        <p class="text-white/70 font-body leading-relaxed max-w-md">
          {{ product.metafields.custom.short_description }}
        </p>
      {% endif %}

      {% form 'product', product %}

        <!-- Variant / Size selector -->
        {% if product.variants.size > 1 %}
          <div class="space-y-4">
            <div class="flex justify-between items-end">
              <label class="font-label text-xs uppercase tracking-widest text-white/50">
                {{ product.options.first }}
              </label>
            </div>
            <div class="grid grid-cols-4 md:grid-cols-8 gap-1">
              {% for variant in product.variants %}
                <button type="button"
                        onclick="document.getElementById('variant-id').value='{{ variant.id }}'; this.closest('.grid').querySelectorAll('button').forEach(b=>b.classList.remove('border-primary','text-primary','bg-primary/10')); this.classList.add('border-primary','text-primary','bg-primary/10')"
                        class="h-12 border border-white/10 flex items-center justify-center font-label text-sm hover:bg-primary hover:text-on-primary transition-colors {% unless variant.available %}opacity-30 cursor-not-allowed{% endunless %}">
                  {{ variant.title }}
                </button>
              {% endfor %}
            </div>
            <input type="hidden" name="id" id="variant-id" value="{{ product.variants.first.id }}">
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% endif %}

        <!-- CTAs -->
        <div class="space-y-4 pt-4">
          {% if product.available %}
            <button type="submit" name="add"
                    class="w-full bg-gradient-to-r from-primary to-primary-container h-16 text-on-primary-fixed font-headline font-extrabold uppercase tracking-widest hover:scale-[1.02] active:scale-95 transition-transform">
              In den Warenkorb legen
            </button>
          {% else %}
            <button disabled
                    class="w-full bg-surface-container-highest h-16 text-white/30 font-headline font-extrabold uppercase tracking-widest cursor-not-allowed">
              Ausverkauft
            </button>
          {% endif %}
          {{ form | payment_button }}
        </div>

      {% endform %}

      <!-- Accordion -->
      <div class="border-t border-white/10 pt-8 mt-4 space-y-6">
        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-2 list-none">
            <h4 class="font-label uppercase tracking-widest text-sm">Shipping & Returns</h4>
            <span class="text-primary text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-xs text-white/50 leading-relaxed font-body mt-3">
            Express shipping worldwide. Swiss orders arrive in 2-3 business days. Free returns within 14 days.
          </p>
        </details>
        <details class="group cursor-pointer">
          <summary class="flex justify-between items-center py-2 list-none">
            <h4 class="font-label uppercase tracking-widest text-sm">Materials & Care</h4>
            <span class="text-primary text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-xs text-white/50 leading-relaxed font-body mt-3">
            Wash cold inside out. Do not tumble dry. Iron on low heat (exclude print areas).
          </p>
        </details>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main Product – Night Runner",
  "settings": []
}
{% endschema %}
