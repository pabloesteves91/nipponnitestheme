<main class="pt-32 pb-20 px-6 md:px-12 lg:px-24 bg-surface min-h-screen">

  <!-- Hero Header -->
  <section class="mb-24">
    <h1 class="font-headline text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-4">
      PIT <span class="text-primary italic">STOP</span>
    </h1>
    <p class="font-label text-sm tracking-[0.3em] uppercase opacity-60">Technischer Support &amp; Globale Kommunikation</p>
  </section>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">

    <!-- Left Column: Contact Form -->
    <div class="lg:col-span-7 space-y-24">

      <div class="space-y-12">
        <div class="space-y-4">
          <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter">KONTAKT AUFNEHMEN</h2>
          <div class="w-24 h-1 bg-primary"></div>
        </div>

        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="bg-surface-container-low p-8 border-l-4 border-primary">
              <p class="font-headline font-bold uppercase text-primary">Nachricht gesendet. Wir melden uns.</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="bg-surface-container-low p-8 border-l-4 border-red-500">
              <p class="font-headline font-bold uppercase text-red-400">{{ form.errors | default_errors }}</p>
            </div>
          {% endif %}

          <div class="space-y-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
              <div class="space-y-2">
                <label class="font-label text-[10px] tracking-[0.2em] uppercase opacity-50" for="contact-name">Name</label>
                <input
                  id="contact-name"
                  type="text"
                  name="contact[name]"
                  value="{{ form.name }}"
                  placeholder="DEIN NAME"
                  class="w-full bg-transparent border-b-2 border-surface-variant focus:border-primary outline-none py-3 font-headline text-lg transition-colors placeholder:text-white/10 uppercase"
                >
              </div>
              <div class="space-y-2">
                <label class="font-label text-[10px] tracking-[0.2em] uppercase opacity-50" for="contact-email">E-Mail</label>
                <input
                  id="contact-email"
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  placeholder="CONTACT@DOMAIN.COM"
                  required
                  class="w-full bg-transparent border-b-2 border-surface-variant focus:border-primary outline-none py-3 font-headline text-lg transition-colors placeholder:text-white/10 uppercase"
                >
              </div>
            </div>

            <div class="space-y-2">
              <label class="font-label text-[10px] tracking-[0.2em] uppercase opacity-50" for="contact-subject">Betreff</label>
              <select
                id="contact-subject"
                name="contact[subject]"
                class="w-full bg-surface border-b-2 border-surface-variant focus:border-primary outline-none py-3 font-headline text-lg transition-colors appearance-none cursor-pointer text-white/80"
              >
                <option value="BESTELLSTATUS">BESTELLSTATUS</option>
                <option value="VERSANDANFRAGE">VERSANDANFRAGE</option>
                <option value="CUSTOM ANFRAGE">CUSTOM ANFRAGE</option>
                <option value="GROSSHANDEL">GROSSHANDEL</option>
              </select>
            </div>

            <div class="space-y-2">
              <label class="font-label text-[10px] tracking-[0.2em] uppercase opacity-50" for="contact-body">Nachricht</label>
              <textarea
                id="contact-body"
                name="contact[body]"
                rows="4"
                placeholder="DEINE NACHRICHT..."
                class="w-full bg-transparent border-b-2 border-surface-variant focus:border-primary outline-none py-3 font-headline text-lg transition-colors resize-none placeholder:text-white/10 uppercase"
              >{{ form.body }}</textarea>
            </div>

            <button
              type="submit"
              class="w-full md:w-auto px-12 py-5 bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-headline font-black uppercase tracking-widest text-lg hover:brightness-110 active:scale-[0.98] transition-all"
            >
              NACHRICHT SENDEN
            </button>
          </div>
        {% endform %}
      </div>

      <!-- Tokyo HQ -->
      <div class="space-y-8">
        <h2 class="font-headline text-2xl font-bold uppercase tracking-tighter">HEADQUARTER</h2>
        <div class="relative w-full aspect-video overflow-hidden">
          <div class="absolute inset-0 bg-primary/5 mix-blend-overlay z-10 pointer-events-none"></div>
          {% if section.settings.hq_image != blank %}
            <img
              src="{{ section.settings.hq_image | img_url: '1200x' }}"
              alt="{{ section.settings.hq_image.alt | escape }}"
              class="w-full h-full object-cover grayscale brightness-50 contrast-125"
            >
          {% else %}
            <div class="w-full h-full bg-surface-container-high flex items-center justify-center">
              <span class="font-headline text-white/10 text-4xl uppercase font-black">Winterthur</span>
            </div>
          {% endif %}
          <div class="absolute bottom-8 left-8 z-20 space-y-2">
            <p class="font-headline text-xl font-bold">SWITZERLAND</p>
            <p class="font-body text-xs tracking-widest opacity-70">IM GRÜNTAL 10 | 8405 WINTERTHUR ZH</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Right Column: FAQ & Social -->
    <div class="lg:col-span-5 space-y-24">

      <!-- FAQ -->
      <div class="space-y-12">
        <div class="space-y-4">
          <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter">FAQ</h2>
          <div class="w-24 h-1 bg-primary"></div>
        </div>
        <div class="space-y-6">
          <div class="bg-surface-container-low p-8 border-l-4 border-transparent hover:border-primary transition-all">
            <h3 class="font-headline font-bold text-lg mb-4 uppercase">VERSAND</h3>
            <p class="text-sm text-on-surface/60 leading-relaxed uppercase">
              Alle Bestellungen werden innerhalb von 48 Stunden bearbeitet. Internationaler Versand dauert 7–14 Werktage. Tracking-Nummern werden nach dem Versand mitgeteilt.
            </p>
          </div>
          <div class="bg-surface-container-low p-8 border-l-4 border-transparent hover:border-primary transition-all">
            <h3 class="font-headline font-bold text-lg mb-4 uppercase">RÜCKGABE &amp; RÜCKERSTATTUNG</h3>
            <p class="text-sm text-on-surface/60 leading-relaxed uppercase">
              Rückgaben sind innerhalb von 14 Tagen möglich. Artikel müssen ungetragen und mit Etikett zurückgesendet werden. Custom-Produkte sind vom Umtausch ausgeschlossen.
            </p>
          </div>
          <div class="bg-surface-container-low p-8 border-l-4 border-transparent hover:border-primary transition-all">
            <h3 class="font-headline font-bold text-lg mb-4 uppercase">CUSTOM ANFRAGE</h3>
            <p class="text-sm text-on-surface/60 leading-relaxed uppercase">
              Custom-Anfragen erfordern eine Anzahlung von 50%. Die Lieferzeit beträgt je nach Verfügbarkeit 4–6 Wochen.
            </p>
          </div>
        </div>
      </div>

      <!-- Social -->
      <div class="space-y-8">
        <h2 class="font-headline text-2xl font-bold uppercase tracking-tighter">COMMUNITY</h2>
        <div class="grid grid-cols-2 gap-4">
          {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" class="group flex items-center justify-between p-6 bg-surface-container-highest hover:bg-primary transition-colors duration-300" target="_blank" rel="noopener">
            <span class="font-headline font-bold group-hover:text-on-primary-fixed">INSTAGRAM</span>
            <span class="material-symbols-outlined group-hover:text-on-primary-fixed">open_in_new</span>
          </a>
          {% endif %}
          {% if section.settings.twitter_url != blank %}
          <a href="{{ section.settings.twitter_url }}" class="group flex items-center justify-between p-6 bg-surface-container-highest hover:bg-primary transition-colors duration-300" target="_blank" rel="noopener">
            <span class="font-headline font-bold group-hover:text-on-primary-fixed">TWITTER / X</span>
            <span class="material-symbols-outlined group-hover:text-on-primary-fixed">open_in_new</span>
          </a>
          {% endif %}
          {% if section.settings.discord_url != blank %}
          <a href="{{ section.settings.discord_url }}" class="group flex items-center justify-between p-6 bg-surface-container-highest hover:bg-primary transition-colors duration-300" target="_blank" rel="noopener">
            <span class="font-headline font-bold group-hover:text-on-primary-fixed">DISCORD</span>
            <span class="material-symbols-outlined group-hover:text-on-primary-fixed">open_in_new</span>
          </a>
          {% endif %}
          {% if section.settings.youtube_url != blank %}
          <a href="{{ section.settings.youtube_url }}" class="group flex items-center justify-between p-6 bg-surface-container-highest hover:bg-primary transition-colors duration-300" target="_blank" rel="noopener">
            <span class="font-headline font-bold group-hover:text-on-primary-fixed">YOUTUBE</span>
            <span class="material-symbols-outlined group-hover:text-on-primary-fixed">open_in_new</span>
          </a>
          {% endif %}
        </div>
      </div>

      <!-- Live Support Badge -->
      <div class="bg-surface-container-highest p-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
          <span class="font-label text-xs tracking-widest uppercase font-bold">LIVE SUPPORT ONLINE</span>
        </div>
        <span class="font-label text-[10px] opacity-40 uppercase">Ø ANTWORTZEIT: 12H</span>
      </div>

    </div>
  </div>

</main>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "hq_image",
      "label": "Tokyo HQ Image"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter / X URL"
    },
    {
      "type": "url",
      "id": "discord_url",
      "label": "Discord URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
