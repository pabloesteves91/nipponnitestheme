{% assign p1 = all_products[section.settings.product1] %}
{% assign p2 = all_products[section.settings.product2] %}

<!-- Tokyo Drift Featured -->
<section class="bg-surface py-32 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-baseline mb-20 gap-8">
      <h2 class="font-headline text-4xl md:text-6xl uppercase font-black tracking-tighter">
        {{ section.settings.title_line1 }}<br>
        <span class="text-primary-fixed-dim">{{ section.settings.title_line2 }}</span>
      </h2>
      <p class="max-w-md text-tertiary-container font-body leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {% if p1.title == blank and p2.title == blank %}
        <p class="col-span-2 text-white/30 text-center py-20">Produkte im Theme-Editor auswählen.</p>
      {% endif %}

      {% if p1.title != blank %}
        <div class="group">
          <div class="aspect-[4/5] overflow-hidden bg-surface-container-low relative">
            {% if p1.featured_image %}
              <a href="{{ p1.url }}" class="block w-full h-full">
                <img src="{{ p1.featured_image | img_url: '800x1000', crop: 'center' }}"
                     alt="{{ p1.featured_image.alt | default: p1.title | escape }}"
                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
              </a>
            {% else %}
              <div class="w-full h-full bg-surface-container-highest"></div>
            {% endif %}
          </div>
          <div class="bg-surface-container-low px-6 py-6 flex justify-between items-start gap-4">
            <div>
              {% if p1.type != blank %}<span class="text-primary text-[10px] tracking-[0.2em] font-bold uppercase block mb-1">{{ p1.type }}</span>{% endif %}
              <h3 class="font-headline text-xl uppercase font-bold leading-tight">
                <a href="{{ p1.url }}" class="hover:text-primary transition-colors">{{ p1.title }}</a>
              </h3>
              {%- assign _p1_count = p1.metafields.reviews.rating_count | default: 0 | plus: 0 -%}
              {%- assign _p1_rating = p1.metafields.reviews.rating.value | default: 0 | times: 1.0 -%}
              {%- assign _p1_full = _p1_rating | floor -%}
              <div style="display:flex;align-items:center;gap:8px;margin-top:5px;">
                {%- if _p1_count > 0 -%}
                  {%- for i in (1..5) -%}{%- if i <= _p1_full -%}<span style="color:#ffffff;font-size:13px;line-height:1;">★</span>{%- else -%}<span style="color:#ffffff;font-size:13px;line-height:1;opacity:0.25;">★</span>{%- endif -%}{%- endfor -%}
                  <span style="color:rgba(255,255,255,0.3);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">{{ _p1_count }} Bewertungen</span>
                {%- else -%}
                  <span style="color:#ffffff;font-size:13px;letter-spacing:2px;line-height:1;">☆☆☆☆☆</span>
                  <span style="color:rgba(255,255,255,0.3);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">0 Bewertungen</span>
                {%- endif -%}
              </div>
            </div>
            <span class="font-headline font-bold text-lg text-on-surface/80 shrink-0">{% if p1.price_varies %}ab {% endif %}{{ p1.price_min | money }}</span>
          </div>
        </div>
      {% endif %}

      {% if p2.title != blank %}
        <div class="group">
          <div class="aspect-[4/5] overflow-hidden bg-surface-container-low relative">
            {% if p2.featured_image %}
              <a href="{{ p2.url }}" class="block w-full h-full">
                <img src="{{ p2.featured_image | img_url: '800x1000', crop: 'center' }}"
                     alt="{{ p2.featured_image.alt | default: p2.title | escape }}"
                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
              </a>
            {% else %}
              <div class="w-full h-full bg-surface-container-highest"></div>
            {% endif %}
          </div>
          <div class="bg-surface-container-low px-6 py-6 flex justify-between items-start gap-4">
            <div>
              {% if p2.type != blank %}<span class="text-primary text-[10px] tracking-[0.2em] font-bold uppercase block mb-1">{{ p2.type }}</span>{% endif %}
              <h3 class="font-headline text-xl uppercase font-bold leading-tight">
                <a href="{{ p2.url }}" class="hover:text-primary transition-colors">{{ p2.title }}</a>
              </h3>
              {%- assign _p2_count = p2.metafields.reviews.rating_count | default: 0 | plus: 0 -%}
              {%- assign _p2_rating = p2.metafields.reviews.rating.value | default: 0 | times: 1.0 -%}
              {%- assign _p2_full = _p2_rating | floor -%}
              <div style="display:flex;align-items:center;gap:8px;margin-top:5px;">
                {%- if _p2_count > 0 -%}
                  {%- for i in (1..5) -%}{%- if i <= _p2_full -%}<span style="color:#ffffff;font-size:13px;line-height:1;">★</span>{%- else -%}<span style="color:#ffffff;font-size:13px;line-height:1;opacity:0.25;">★</span>{%- endif -%}{%- endfor -%}
                  <span style="color:rgba(255,255,255,0.3);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">{{ _p2_count }} Bewertungen</span>
                {%- else -%}
                  <span style="color:#ffffff;font-size:13px;letter-spacing:2px;line-height:1;">☆☆☆☆☆</span>
                  <span style="color:rgba(255,255,255,0.3);font-size:10px;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:0.1em;">0 Bewertungen</span>
                {%- endif -%}
              </div>
            </div>
            <span class="font-headline font-bold text-lg text-on-surface/80 shrink-0">{% if p2.price_varies %}ab {% endif %}{{ p2.price_min | money }}</span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Duo",
  "settings": [
    { "type": "product", "id": "product1", "label": "Produkt 1" },
    { "type": "product", "id": "product2", "label": "Produkt 2" },
    { "type": "text",    "id": "title_line1", "label": "Titel Zeile 1", "default": "Tokyo Drift" },
    { "type": "text",    "id": "title_line2", "label": "Titel Zeile 2", "default": "Edition" },
    { "type": "textarea","id": "description", "label": "Beschreibung",  "default": "Inspired by the underground night meets of Shinjuku and the relentless pursuit of speed." }
  ],
  "presets": [{ "name": "Featured Duo" }]
}
{% endschema %}
