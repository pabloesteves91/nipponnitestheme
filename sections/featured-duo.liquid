{% assign p1 = all_products[section.settings.product1] %}
{% assign p2 = all_products[section.settings.product2] %}

<!-- Tokyo Drift Featured -->
<section class="bg-surface py-32 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-baseline mb-20 gap-8">
      <h2 class="font-headline text-4xl md:text-6xl uppercase font-black tracking-tighter">
        {{ section.settings.title_line1 }}<br>
        <span class="text-primary-fixed-dim">{{ section.settings.title_line2 }}</span>
      </h2>
      <p class="max-w-md text-tertiary-container font-body leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {% assign duo_products = '' | split: '' %}
      {% if p1 and p1.title != blank %}{% assign duo_products = duo_products | push: p1 %}{% endif %}
      {% if p2 and p2.title != blank %}{% assign duo_products = duo_products | push: p2 %}{% endif %}

      {% if duo_products.size > 0 %}
        {% for product in duo_products %}
          <div class="group">
            <div class="aspect-[4/5] overflow-hidden bg-surface-container-low relative">
              {% if product.featured_image %}
                <a href="{{ product.url }}" class="block w-full h-full">
                  <img src="{{ product.featured_image | img_url: '800x1000', crop: 'center' }}"
                       alt="{{ product.featured_image.alt | default: product.title | escape }}"
                       class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </a>
              {% else %}
                <div class="w-full h-full bg-surface-container-highest"></div>
              {% endif %}
            </div>
            <div class="bg-surface-container-low px-6 py-6 flex justify-between items-start gap-4">
              <div>
                {% if product.type != blank %}
                  <span class="text-primary text-[10px] tracking-[0.2em] font-bold uppercase block mb-1">{{ product.type }}</span>
                {% endif %}
                <h3 class="font-headline text-xl uppercase font-bold leading-tight">
                  <a href="{{ product.url }}" class="hover:text-primary transition-colors">{{ product.title }}</a>
                </h3>
              </div>
              <span class="font-headline font-bold text-lg text-on-surface/80 shrink-0">{% if product.price_varies %}ab {% endif %}{{ product.price_min | money }}</span>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p class="col-span-2 text-white/30 text-center py-20">Produkte im Theme-Editor auswählen.</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Duo",
  "settings": [
    { "type": "product", "id": "product1", "label": "Produkt 1" },
    { "type": "product", "id": "product2", "label": "Produkt 2" },
    { "type": "text",    "id": "title_line1", "label": "Titel Zeile 1", "default": "Tokyo Drift" },
    { "type": "text",    "id": "title_line2", "label": "Titel Zeile 2", "default": "Edition" },
    { "type": "textarea","id": "description", "label": "Beschreibung",  "default": "Inspired by the underground night meets of Shinjuku and the relentless pursuit of speed." }
  ],
  "presets": [{ "name": "Featured Duo" }]
}
{% endschema %}
