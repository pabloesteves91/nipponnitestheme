{% if section.settings.show_announcement %}
<div id="announcement-bar" class="bg-primary text-white text-center py-2 px-4 text-sm font-display font-bold tracking-widest uppercase relative">
  {{ section.settings.announcement_text | escape }}
  <button id="dismiss-announcement" class="absolute right-4 top-1/2 -translate-y-1/2 opacity-60 hover:opacity-100" aria-label="Dismiss">✕</button>
</div>
{% endif %}
{% schema %}{"name":"Announcement Bar","settings":[{"type":"checkbox","id":"show_announcement","label":"Show announcement bar","default":true},{"type":"text","id":"announcement_text","label":"Announcement text","default":"Free shipping on orders over ¥10,000 🇯🇵"}],"presets":[{"name":"Announcement Bar"}]}{% endschema %}
