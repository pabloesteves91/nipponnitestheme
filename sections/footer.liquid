<footer class="bg-[#0e0e0e] border-t border-white/5">

  <!-- Newsletter Bar -->
  <div class="bg-surface-container-low border-b border-white/5">
    <div class="max-w-screen-xl mx-auto px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-headline font-black text-2xl uppercase tracking-tighter">Bleib im Loop</p>
        <p class="text-white/40 text-sm font-body mt-1">Limited Drops, News & exklusive Angebote.</p>
      </div>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="flex w-full md:w-auto">
          <input
            type="email"
            name="contact[email]"
            placeholder="DEINE E-MAIL"
            class="bg-transparent border border-outline-variant text-white font-headline text-sm tracking-widest px-6 py-4 flex-1 md:w-72 focus:outline-none focus:border-primary placeholder:text-white/20"
            required
          >
          <button type="submit" class="bg-primary text-on-primary-fixed font-headline font-bold uppercase tracking-widest px-8 py-4 text-sm hover:brightness-110 transition-all shrink-0">
            →
          </button>
        </div>
      {% endform %}
    </div>
  </div>

  <!-- Main Footer -->
  <div class="max-w-screen-xl mx-auto px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand + Social -->
      <div class="space-y-6">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" class="h-10 w-auto">
        {% else %}
          <p class="font-headline font-black text-xl tracking-tighter">{{ shop.name | upcase }}</p>
        {% endif %}
        <p class="text-white/40 text-sm font-body leading-relaxed">{{ section.settings.tagline }}</p>
        <div class="flex gap-5 pt-2">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="text-white/40 hover:text-primary transition-colors" aria-label="Instagram">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" class="text-white/40 hover:text-primary transition-colors" aria-label="TikTok">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.75a8.27 8.27 0 0 0 4.84 1.55V6.84a4.85 4.85 0 0 1-1.07-.15z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" class="text-white/40 hover:text-primary transition-colors" aria-label="YouTube">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Navigate -->
      <div>
        <p class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-white/30 mb-6">Navigation</p>
        <ul class="space-y-3">
          {% for link in linklists[section.settings.footer_menu].links %}
            <li><a href="{{ link.url }}" class="text-white/60 hover:text-primary text-sm font-body transition-colors">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-white/30 mb-6">Legal</p>
        <ul class="space-y-3">
          {% for policy in shop.policies %}
            {% if policy.body != blank %}
              <li><a href="{{ policy.url }}" class="text-white/60 hover:text-primary text-sm font-body transition-colors">{{ policy.title }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-white/30 mb-6">Kontakt</p>
        <ul class="space-y-2 text-white/50 text-sm font-body">
          <li>Im Grüntal 10</li>
          <li>8405 Winterthur ZH</li>
          <li>Switzerland</li>
          <li class="pt-3">
            <a href="/pages/contact" class="text-primary hover:brightness-110 transition-all font-headline font-bold text-xs tracking-widest uppercase">→ Kontaktformular</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/20 text-xs font-body">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p class="text-white/20 text-xs font-body uppercase tracking-widest">Tokyo Underground · Winterthur</p>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer Logo" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Tokyo Underground Streetwear. Hand-illustriert. Bio-Baumwolle." },
    { "type": "link_list", "id": "footer_menu", "label": "Footer Menü", "default": "footer" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
