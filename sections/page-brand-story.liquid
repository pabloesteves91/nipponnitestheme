<!-- Hero Section -->
<header class="relative min-h-screen flex items-end pt-32 pb-20 px-8 lg:px-16 overflow-hidden bg-surface">
  <div class="absolute inset-0 z-0">
    {% if section.settings.hero_image != blank %}
      <img
        src="{{ section.settings.hero_image | img_url: '2000x' }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        class="w-full h-full object-cover grayscale opacity-60 contrast-125"
      >
    {% else %}
      <div class="w-full h-full bg-surface-container-high"></div>
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-surface/20"></div>
  </div>
  <div class="relative z-10 w-full">
    <p class="font-label text-primary tracking-[0.4em] uppercase mb-4 text-sm md:text-base">ESTABLISHED IN THE DARK</p>
    <h1 class="font-headline font-black text-6xl md:text-[10rem] leading-[0.85] uppercase tracking-tighter mb-8 italic">
      PASSION <span style="-webkit-text-stroke: 2px #ffb4a9; color: transparent;">IS NOT A</span><br>CRIME.
    </h1>
    <div class="flex flex-col md:flex-row gap-12 md:items-end">
      <p class="max-w-md text-on-surface/70 font-medium text-lg border-l-2 border-primary pl-6">
        Born from the asphalt of the Shuto Expressway and the neon glow of Akihabara. We don't just sell clothes; we export the adrenaline of the midnight run.
      </p>
      <div class="font-headline font-bold text-3xl tracking-tighter text-primary/40 uppercase">
        00:00 — 05:00
      </div>
    </div>
  </div>
</header>

<!-- Section: Born on Asphalt -->
<section class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7 relative order-2 md:order-1">
        {% if section.settings.vision_image != blank %}
          <img
            src="{{ section.settings.vision_image | img_url: '1200x' }}"
            alt="{{ section.settings.vision_image.alt | escape }}"
            class="w-full h-[600px] object-cover"
          >
        {% else %}
          <div class="w-full h-[600px] bg-surface-container-high"></div>
        {% endif %}
        <div class="absolute -bottom-10 -right-10 hidden lg:block bg-surface-container-highest p-12 w-80">
          <p class="font-headline text-primary font-bold text-2xl mb-4">THE VISION</p>
          <p class="text-sm text-on-surface/60 leading-relaxed">
            To bridge the gap between technical automotive culture and high-end street aesthetics. We design for the drivers, the dreamers, and the deviants.
          </p>
        </div>
      </div>
      <div class="md:col-span-5 order-1 md:order-2">
        <h2 class="font-headline font-black text-5xl md:text-7xl uppercase tracking-tighter mb-8 leading-none">
          BORN ON<br><span class="text-primary">ASPHALT</span>
        </h2>
        <div class="space-y-6 text-on-surface/60 max-w-sm">
          <p>NIPPON NITES started as a small circle of enthusiasts in the late 90s, meeting at Daikoku Futo PA. It wasn't about the fame—it was about the machine and the man.</p>
          <p>Our gear is designed to withstand the G-forces of a hairpin turn and the scrutiny of the fashion elite. Every stitch is a tribute to the legendary tuning houses of Tokyo.</p>
          <div class="pt-8">
            <a href="/collections/all" class="group flex items-center gap-4 text-primary font-headline font-bold tracking-widest uppercase text-sm">
              Explore Heritage
              <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section: Engineered Precision -->
<section class="bg-surface-container-low py-40">
  <div class="px-8 lg:px-16">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-24 gap-8">
      <h2 class="font-headline font-black text-6xl md:text-9xl uppercase tracking-tighter leading-none">
        ENGINEERED<br>PRECISION
      </h2>
      <div class="max-w-xs">
        <p class="font-label text-primary uppercase tracking-widest mb-4">QUALITY SPECS</p>
        <p class="text-on-surface/60">We treat fabric like chassis—it needs to be durable, lightweight, and perfectly balanced.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
      <div class="bg-surface p-12 flex flex-col justify-between h-[450px] group hover:bg-primary transition-colors duration-500">
        <span class="material-symbols-outlined text-4xl text-primary group-hover:text-on-primary-fixed" style="font-variation-settings: 'FILL' 1;">architecture</span>
        <div>
          <h3 class="font-headline font-bold text-2xl mb-4 group-hover:text-on-primary-fixed uppercase">Heavyweight Fabric</h3>
          <p class="text-on-surface/60 group-hover:text-on-primary-fixed/80">450GSM French Terry. Pre-shrunk. Built to last longer than your tires.</p>
        </div>
      </div>
      <div class="bg-surface p-12 flex flex-col justify-between h-[450px] group hover:bg-primary transition-colors duration-500">
        <span class="material-symbols-outlined text-4xl text-primary group-hover:text-on-primary-fixed" style="font-variation-settings: 'FILL' 1;">speed</span>
        <div>
          <h3 class="font-headline font-bold text-2xl mb-4 group-hover:text-on-primary-fixed uppercase">Performance Fit</h3>
          <p class="text-on-surface/60 group-hover:text-on-primary-fixed/80">Oversized silhouettes designed for unrestricted movement and maximum comfort.</p>
        </div>
      </div>
      <div class="bg-surface p-12 flex flex-col justify-between h-[450px] group hover:bg-primary transition-colors duration-500">
        <span class="material-symbols-outlined text-4xl text-primary group-hover:text-on-primary-fixed" style="font-variation-settings: 'FILL' 1;">verified</span>
        <div>
          <h3 class="font-headline font-bold text-2xl mb-4 group-hover:text-on-primary-fixed uppercase">Artisan Finish</h3>
          <p class="text-on-surface/60 group-hover:text-on-primary-fixed/80">Screen-printed in limited batches using high-density inks for a textured feel.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Zine Section -->
<section class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-12 gap-8 items-start">
      <div class="col-span-12 md:col-span-4 aspect-[3/4] overflow-hidden">
        {% if section.settings.zine_image != blank %}
          <img
            src="{{ section.settings.zine_image | img_url: '800x' }}"
            alt="{{ section.settings.zine_image.alt | escape }}"
            class="w-full h-full object-cover grayscale"
          >
        {% else %}
          <div class="w-full h-full bg-surface-container-high"></div>
        {% endif %}
      </div>
      <div class="col-span-12 md:col-span-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="md:pt-40">
            <h4 class="font-headline font-black text-4xl uppercase mb-6 italic">NO REARVIEW MIRRORS</h4>
            <p class="text-on-surface/60 leading-relaxed">
              Our community isn't built on looking back. We are constantly pushing the envelope of what streetwear can represent. For us, every collection is a new lap time to beat.
            </p>
          </div>
          <div class="aspect-square bg-surface-container-high relative flex items-center justify-center">
            {% if section.settings.zine_accent_image != blank %}
              <div class="absolute inset-0 overflow-hidden">
                <img
                  src="{{ section.settings.zine_accent_image | img_url: '600x' }}"
                  alt="{{ section.settings.zine_accent_image.alt | escape }}"
                  class="w-full h-full object-cover opacity-30"
                >
              </div>
            {% endif %}
            <div class="relative z-10 text-center p-8 border border-primary/20">
              <p class="font-headline font-bold text-6xl text-primary mb-2">LIMITED</p>
              <p class="font-label tracking-[0.5em] text-xs">EDITION RUNS ONLY</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA: Join the Underground -->
<section class="relative h-[70vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    {% if section.settings.cta_image != blank %}
      <img
        src="{{ section.settings.cta_image | img_url: '2000x' }}"
        alt="{{ section.settings.cta_image.alt | escape }}"
        class="w-full h-full object-cover grayscale brightness-50"
      >
    {% else %}
      <div class="w-full h-full bg-surface-container-low"></div>
    {% endif %}
  </div>
  <div class="relative z-10 text-center px-8">
    <h2 class="font-headline font-black text-6xl md:text-9xl uppercase tracking-tighter mb-12">
      JOIN THE<br><span class="text-primary italic">UNDERGROUND</span>
    </h2>
    <div class="flex flex-col md:flex-row gap-6 justify-center">
      <a href="/collections/all" class="bg-gradient-to-r from-primary to-primary-container px-12 py-6 font-headline font-black uppercase text-on-primary-fixed tracking-widest text-xl hover:brightness-110 active:scale-[0.98] transition-all">
        SHOP THE DROP
      </a>
      <a href="/pages/contact" class="border-2 border-outline-variant px-12 py-6 font-headline font-black uppercase tracking-widest text-xl hover:bg-surface-container-highest transition-colors active:scale-[0.98]">
        CONTACT US
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "header",
      "content": "Vision Section"
    },
    {
      "type": "image_picker",
      "id": "vision_image",
      "label": "Vision Image"
    },
    {
      "type": "header",
      "content": "Zine Section"
    },
    {
      "type": "image_picker",
      "id": "zine_image",
      "label": "Zine Portrait Image"
    },
    {
      "type": "image_picker",
      "id": "zine_accent_image",
      "label": "Zine Accent Image"
    },
    {
      "type": "header",
      "content": "CTA Section"
    },
    {
      "type": "image_picker",
      "id": "cta_image",
      "label": "CTA Background Image"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
