<style>
  .pp-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 92vh;
  }
  .pp-img {
    position: relative;
    overflow: hidden;
  }
  .pp-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .pp-img-placeholder {
    position: absolute;
    inset: 0;
    background: #1b1b1b;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pp-content {
    display: flex;
    align-items: center;
    padding: 5rem 4.5rem;
  }
  .pp-inner { max-width: 30rem; width: 100%; }
  .pp-eyebrow {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #ffb4a9;
    margin: 0 0 1.25rem;
  }
  .pp-h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin: 0 0 1.5rem;
  }
  .pp-body {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.75;
    margin: 0 0 2.5rem;
  }
  .pp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(to right, #ffb4a9, #fb5a48);
    color: #410000;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 900;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem 2rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: filter 0.2s;
  }
  .pp-cta:hover { filter: brightness(1.07); }
  .pp-check-list { display: flex; flex-direction: column; gap: 1.75rem; }
  .pp-check-item { display: flex; gap: 1.25rem; align-items: flex-start; }
  .pp-check-icon {
    width: 2.25rem;
    height: 2.25rem;
    border: 1.5px solid rgba(255,180,169,0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .pp-check-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin: 0 0 0.35rem;
  }
  .pp-check-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.38);
    margin: 0;
    line-height: 1.65;
  }
  .pp-form-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 2rem;
    line-height: 1.05;
  }
  @media (max-width: 767px) {
    .pp-split { grid-template-columns: 1fr; min-height: auto; }
    .pp-img { min-height: 60vw; }
    .pp-content { padding: 3rem 1.5rem; }
    .pp-mob-first { order: -1; }
  }
</style>

<!-- ── 1. HERO: Bild links · Text rechts ─────────────────────────────────────── -->
<section class="pp-split" style="background:#131313;">

  <div class="pp-img">
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | img_url: '1000x1400', crop: 'center' }}" alt="">
    {% else %}
      <div class="pp-img-placeholder">
        <p style="font-family:'Space Grotesk';font-size:10px;text-transform:uppercase;letter-spacing:0.2em;color:rgba(255,255,255,0.12);">Bild wählen</p>
      </div>
    {% endif %}
  </div>

  <div class="pp-content" style="background:#131313;">
    <div class="pp-inner">
      <p class="pp-eyebrow">Affiliate Program</p>
      <h1 class="pp-h1">{{ section.settings.hero_title | default: 'Das lukrativste Affiliate Program' }}</h1>
      <p class="pp-body">{{ section.settings.hero_text | default: 'Trete unserem Affiliate-Programm bei und werde Teil der Nippon Nites Community. Du hast die einzigartige Möglichkeit, deine Leidenschaft für japanische Streetwear zu teilen und dabei attraktive Provisionen zu verdienen.' }}</p>
      <a href="#partner-form" class="pp-cta">Jetzt anmelden &nbsp;→</a>
    </div>
  </div>

</section>

<!-- ── 2. BENEFITS: Text links · Bild rechts ─────────────────────────────────── -->
<section class="pp-split" style="background:#0e0e0e;">

  <div class="pp-content" style="background:#0e0e0e;">
    <div class="pp-inner">
      <p class="pp-eyebrow">Vorteile</p>
      <h2 class="pp-h1" style="font-size:clamp(1.75rem,3vw,2.5rem);margin-bottom:2.25rem;">Entdecke die Vorteile der Partnerschaft</h2>

      <div class="pp-check-list">
        <div class="pp-check-item">
          <div class="pp-check-icon">
            <span class="material-symbols-outlined" style="font-size:15px;color:#ffb4a9;">check</span>
          </div>
          <div>
            <p class="pp-check-title">Commission Rate</p>
            <p class="pp-check-desc">Verdiene 5% Provision auf jeden Kauf, der über deinen Affiliate-Link oder Rabattcode getätigt wird.</p>
          </div>
        </div>
        <div class="pp-check-item">
          <div class="pp-check-icon">
            <span class="material-symbols-outlined" style="font-size:15px;color:#ffb4a9;">check</span>
          </div>
          <div>
            <p class="pp-check-title">Persönlicher Link & Code</p>
            <p class="pp-check-desc">Du erhältst deinen eigenen Affiliate-Link und Rabattcode — direkt einsetzbar für deine Community.</p>
          </div>
        </div>
        <div class="pp-check-item">
          <div class="pp-check-icon">
            <span class="material-symbols-outlined" style="font-size:15px;color:#ffb4a9;">check</span>
          </div>
          <div>
            <p class="pp-check-title">30 Tage Cookie</p>
            <p class="pp-check-desc">Jeder Kauf innerhalb von 30 Tagen nach dem Klick auf deinen Link wird dir angerechnet.</p>
          </div>
        </div>
        <div class="pp-check-item">
          <div class="pp-check-icon">
            <span class="material-symbols-outlined" style="font-size:15px;color:#ffb4a9;">check</span>
          </div>
          <div>
            <p class="pp-check-title">Monatliche Auszahlung</p>
            <p class="pp-check-desc">Deine Provisionen werden monatlich ausbezahlt — zuverlässig und transparent.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pp-img">
    {% if section.settings.benefits_image %}
      <img src="{{ section.settings.benefits_image | img_url: '1000x1400', crop: 'center' }}" alt="">
    {% else %}
      <div class="pp-img-placeholder" style="background:#181818;">
        <p style="font-family:'Space Grotesk';font-size:10px;text-transform:uppercase;letter-spacing:0.2em;color:rgba(255,255,255,0.12);">Bild wählen</p>
      </div>
    {% endif %}
  </div>

</section>

<!-- ── 3. FORM: Bild links · Formular rechts ─────────────────────────────────── -->
<section id="partner-form" class="pp-split" style="background:#131313;">

  <div class="pp-img">
    {% if section.settings.form_image %}
      <img src="{{ section.settings.form_image | img_url: '1000x1400', crop: 'center' }}" alt="">
    {% else %}
      <div class="pp-img-placeholder">
        <p style="font-family:'Space Grotesk';font-size:10px;text-transform:uppercase;letter-spacing:0.2em;color:rgba(255,255,255,0.12);">Bild wählen</p>
      </div>
    {% endif %}
  </div>

  <div class="pp-content" style="background:#131313;align-items:flex-start;flex-direction:column;padding:4rem 4.5rem;overflow-y:auto;">
    <h2 class="pp-form-title">JOIN OUR<br>PROGRAM</h2>
    <div style="width:100%;">
      {%- for block in section.blocks -%}
        {%- render block -%}
      {%- endfor -%}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Partner Page",
  "blocks": [{ "type": "@app" }],
  "settings": [
    { "type": "header",       "content": "Section 1 – Hero" },
    { "type": "image_picker", "id": "hero_image",    "label": "Bild links" },
    { "type": "text",         "id": "hero_title",    "label": "Headline",          "default": "Das lukrativste Affiliate Program" },
    { "type": "textarea",     "id": "hero_text",     "label": "Beschreibungstext" },
    { "type": "header",       "content": "Section 2 – Benefits" },
    { "type": "image_picker", "id": "benefits_image","label": "Bild rechts" },
    { "type": "header",       "content": "Section 3 – Formular" },
    { "type": "image_picker", "id": "form_image",    "label": "Bild links" }
  ],
  "presets": [{ "name": "Partner Page" }]
}
{% endschema %}
