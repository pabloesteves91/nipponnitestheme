<section class="relative min-h-[90vh] flex items-center overflow-hidden gradient-bg">
  {% if section.settings.bg_image != blank %}
    <div class="absolute inset-0 z-0">
      <img src="{{ section.settings.bg_image | img_url: '1920x' }}" alt="" class="w-full h-full object-cover opacity-30">
      <div class="absolute inset-0 bg-gradient-to-r from-night via-night/70 to-transparent"></div>
    </div>
  {% endif %}
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="max-w-2xl">
      {% if section.settings.eyebrow != blank %}<p class="font-display text-primary text-sm font-bold uppercase tracking-[0.3em] mb-4">{{ section.settings.eyebrow }}</p>{% endif %}
      <h1 class="font-display font-black text-6xl md:text-8xl leading-none mb-6 text-white">{{ section.settings.headline }}</h1>
      {% if section.settings.subline != blank %}<p class="text-white/60 text-lg md:text-xl mb-10 max-w-lg">{{ section.settings.subline }}</p>{% endif %}
      <div class="flex flex-wrap gap-4">
        {% if section.settings.cta_primary_label != blank %}<a href="{{ section.settings.cta_primary_url }}" class="btn-primary">{{ section.settings.cta_primary_label }}</a>{% endif %}
        {% if section.settings.cta_secondary_label != blank %}<a href="{{ section.settings.cta_secondary_url }}" class="btn-outline">{{ section.settings.cta_secondary_label }}</a>{% endif %}
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-primary opacity-60"></div>
</section>
{% schema %}{"name":"Hero Banner","settings":[{"type":"image_picker","id":"bg_image","label":"Background image"},{"type":"text","id":"eyebrow","label":"Eyebrow text","default":"New Collection"},{"type":"text","id":"headline","label":"Headline","default":"Night Runner"},{"type":"textarea","id":"subline","label":"Subline","default":"Premium streetwear inspired by Tokyo nights."},{"type":"text","id":"cta_primary_label","label":"Primary button text","default":"Shop Now"},{"type":"url","id":"cta_primary_url","label":"Primary button URL"},{"type":"text","id":"cta_secondary_label","label":"Secondary button text","default":"Learn More"},{"type":"url","id":"cta_secondary_url","label":"Secondary button URL"}],"presets":[{"name":"Hero Banner"}]}{% endschema %}
